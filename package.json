{
  "name": "compile-game",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently -k -n SERVER,CLIENT -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:status": "node scripts/dev-status.js",
    "dev:stop": "node scripts/dev-stop.js",
    "test": "npm run test --workspace=server",
    "test:watch": "npm run test:watch --workspace=server",
    "test:e2e": "node cleanup-tests.js && playwright test",
    "test:e2e:ui": "node cleanup-tests.js && playwright test --ui",
    "test:e2e:debug": "node cleanup-tests.js && playwright test --debug",
    "test:e2e:headed": "node cleanup-tests.js && playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "concurrently": "^9.2.1"
  }
}
